# Session / Auth
SESSION_SECRET=replace-with-a-random-long-string
SUPABASE_URL=https://your-project-ref.supabase.co

# Database
# Prefer the Supabase pooled connection string for local development.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Frontend (exposed to browser via Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_anon_key

# On Vercel, keep the backend and frontend Supabase variables aligned.
SUPABASE_ANON_KEY=your_supabase_publishable_anon_key
SUPABASE_STORAGE_BUCKET=vault-files
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Legacy compatibility
# APP_ID defaults to "supabase" and APP_SECRET falls back to SESSION_SECRET.
APP_ID=supabase
APP_SECRET=

# Chat model provider
# Venice is the only required provider for the Stage 1 chat backend.
VENICE_API_KEY=
# Optional alias accepted by the backend for Venice-created inference keys.
VENICE_INFERENCE_KEY=
VENICE_MODEL=zai-org-glm-5

# Legacy provider variables are not required for the Venice-first chat path.
KIMI_AUTH_URL=
KIMI_OPEN_URL=
KIMI_MODEL=kimi-k2.6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=

# Optional admin role mapping
OWNER_UNION_ID=supabase:YOUR_SUPABASE_AUTH_USER_ID
